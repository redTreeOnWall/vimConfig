{
    "languageserver": {
        "csharp-ls": {
          "command": "csharp-ls",
          "filetypes": ["cs"],
          "rootPatterns": ["*.csproj", ".vim/", ".git/", ".hg/"]
        }
    },
    "cSpell.userWords": [
      "Exacalidraw",
      "Excalidraw",
      "GLTF",
      "Horiz",
      "Raycast",
      "Rigibody",
      "SSAO",
      "Swipeable",
      "Tldraw",
      "darcula",
      "hljs",
      "lirunlong",
      "localstorage",
      "mariadb",
      "memorains",
      "metalness",
      "mixamo",
      "protobuf",
      "threejs",
      "tseslint",
      "wechat"
    ],
    "eslint.experimental.useFlatConfig": true
}
